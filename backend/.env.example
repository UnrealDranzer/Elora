NODE_ENV=development
PORT=8080
APP_NAME=Elora API
APP_URL=http://localhost:8080
STORE_FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
COOKIE_DOMAIN=localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elora
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=10
PAYMENT_RATE_LIMIT_MAX=25
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=optional-webhook-secret
DEFAULT_CURRENCY=INR
LOG_LEVEL=info
SEED_ADMIN_EMAIL=admin@elora.com
SEED_ADMIN_PASSWORD=ChangeThisNow123!
